{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "cropTypeId": {
            "type": "string",
            "prefix": "croptype-",
            "key": "Primary",
            "keyLength": 12,
            "description": "crop type prefix"
        },
        "cropCategoryId": {
            "type": "string",
            "description": "id of the crop category this crop type belongs to"
        },
        "cropCategoryName": {
            "type": "string",
            "description": "name of the crop category this crop type belongs to"
        },
        "name": {
            "type": "string",
            "description": "name of the crop type"
        },
        "scientificName": {
            "type": "string",
            "description": "scientific name of the crop type"
        },
        "centre": {
            "type": "string",
            "description": "research centre of the crop type"
        },
        "varietiesCount": {
            "type": "integer",
            "description": "number of released varieties of the crop type"
        },
        "imageUrl": {
            "type": "string",
            "description": "image url of the crop type"
        },
        "description": {
            "type": "string",
            "description": "description of the crop type"
        }
    },
    "required": [
        "cropCategoryName",
        "name",
        "scientificName",
        "varietiesCount"
    ]
}
