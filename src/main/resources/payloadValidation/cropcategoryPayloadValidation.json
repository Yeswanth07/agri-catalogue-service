{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "cropCategoryId": {
            "type": "string",
            "prefix": "cropcategory-",
            "key": "Primary",
            "keyLength": 5,
            "description": "crop category prefix"
        },
        "name": {
            "type": "string",
            "description": "name of the crop category"
        },
        "imageUrl": {
            "type": "string",
            "description": "image url of the crop category"
        },
        "description": {
            "type": "string",
            "description": "description of the crop category"
        }
    },
    "required": [
        "name",
        "imageUrl"
    ]
}
