{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "locationId": {
            "type": "string",
            "prefix": "location-",
            "key": "Primary",
            "keyLength": 12,
            "description": "location prefix"
        },
        "region": {
            "type": "string",
            "description": "region the market place belongs to"
        },
        "marketPlace": {
            "type": "string",
            "description": "name of the market place"
        }
    },
    "required": [
        "region",
        "marketPlace"
    ]
}
