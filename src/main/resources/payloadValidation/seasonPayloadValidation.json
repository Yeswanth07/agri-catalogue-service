{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "seasonId": {
            "type": "string",
            "prefix": "season-",
            "key": "Primary",
            "keyLength": 12,
            "description": "season prefix"
        },
        "season": {
            "type": "string",
            "description": "name of the season (Kiremt, Tseday, Bega, Belg)"
        },
        "startMonth": {
            "type": "string",
            "description": "gregorian month the season starts in"
        },
        "startDay": {
            "type": "integer",
            "description": "day of the start month the season begins on"
        },
        "endMonth": {
            "type": "string",
            "description": "gregorian month the season ends in"
        },
        "endDay": {
            "type": "integer",
            "description": "day of the end month the season ends on"
        }
    },
    "required": [
        "season",
        "startMonth",
        "startDay",
        "endMonth",
        "endDay"
    ]
}
