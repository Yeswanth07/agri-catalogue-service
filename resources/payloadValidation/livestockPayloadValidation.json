{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "Livestock Id": {
            "type": "string",
            "prefix": "livestock-",
            "key": "Primary",
            "description": "livestock information prefix"
        },
        "Farmer ID": {
            "type": "string",
            "description": "reference to the Farmer record this livestock information belongs to"
        },
        "Farmer": {
            "type": "string"
        },
        "Livestock Type": {
            "type": "string"
        },
        "Number": {
            "type": "integer"
        }
    },
    "required": [
        "Farmer ID",
        "Farmer",
        "Livestock Type",
        "Number"
    ]
}