{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "Season Id": {
            "type": "string",
            "prefix": "season-",
            "key": "Primary",
            "description": "season prefix"
        },
        "Name": {
            "type": "string"
        },
        "Start GC": {
            "type": "string",
            "format": "date"
        },
        "End GC": {
            "type": "string",
            "format": "date"
        },
        "Start Month": {
            "type": "integer"
        },
        "Start Day": {
            "type": "integer"
        },
        "End Month": {
            "type": "integer"
        },
        "End Day": {
            "type": "integer"
        }
    },
    "required": [
        "Name",
        "Start GC",
        "End GC",
        "Start Month",
        "Start Day",
        "End Month",
        "End Day"
    ]
}